# ── Database ────────────────────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:password@host/dbname

# ── Hansa ERP connection ─────────────────────────────────────────────────────
HANSA_BASE_URL=https://your-hansa-server.example.com
HANSA_USERNAME=your_username
HANSA_PASSWORD=your_password
HANSA_COMPANY_NO=3
HANSA_MASTER_COMPANY_NO=1

# ── OpenAI (optional — AI insights panel) ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CORS (comma-separated list of allowed frontend origins) ──────────────────
# Leave as * for open access, or restrict to your Render frontend URL:
# ALLOWED_ORIGINS=https://your-frontend.onrender.com
